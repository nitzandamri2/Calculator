<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#FFF5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="מחשבון חכם"
        android:textSize="28sp"
        android:textColor="#C71585"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/edit_text_first_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="הכנס מספר ראשון"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:gravity="center"
        android:textSize="20sp" />

    <EditText
        android:id="@+id/edit_text_second_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="הכנס מספר שני"
        android:inputType="numberDecimal"
        android:padding="16dp"
        android:background="@android:drawable/editbox_background"
        android:gravity="center"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/text_view_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:text="תוצאה: 0"
        android:textColor="#C71585"
        android:textSize="32sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/button_add"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:backgroundTint="#FFC0CB"
            android:onClick="onOperatorClick"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="26sp" />

        <Button
            android:id="@+id/button_subtract"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:backgroundTint="#FFC0CB"
            android:onClick="onOperatorClick"
            android:text="-"
            android:textColor="#FFFFFF"
            android:textSize="26sp" />

        <Button
            android:id="@+id/button_multiply"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:backgroundTint="#FFC0CB"
            android:onClick="onOperatorClick"
            android:text="×"
            android:textColor="#FFFFFF"
            android:textSize="26sp" />

        <Button
            android:id="@+id/button_divide"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="8dp"
            android:backgroundTint="#FFC0CB"
            android:onClick="onOperatorClick"
            android:text="÷"
            android:textColor="#FFFFFF"
            android:textSize="26sp" />
    </LinearLayout>

    <Button
        android:id="@+id/button_clear"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#FF69B4"
        android:onClick="onClearClick"
        android:text="נקה הכל"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>